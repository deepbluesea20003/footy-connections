{
  "name": "football-separation-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "seed": "tsx --env-file=.env src/scripts/seed-db.ts",
    "fetch": "tsx --env-file=.env src/scripts/fetch-from-api.ts",
    "import:wikidata": "tsx --env-file=.env src/scripts/fetch-from-wikidata.ts",
    "enrich:reep": "tsx --env-file=.env src/scripts/enrich-reep.ts",
    "status": "tsx --env-file=.env src/scripts/status.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
