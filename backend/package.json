{
  "name": "football-separation-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 tsx watch --env-file=.env.spike src/index.ts",
    "build": "tsc",
    "start": "node --max-old-space-size=4096 dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "import:tm": "tsx --env-file=.env.spike src/scripts/import-transfermarkt.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@types/pg": "^8.20.0",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.0",
    "express": "^5.1.0",
    "pg": "^8.22.0",
    "pg-copy-streams": "^7.0.0",
    "pg-query-stream": "^4.16.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
